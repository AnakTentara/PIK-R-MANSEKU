datasource db {
  provider = "sqlite"
  url      = "file:../local.db"
}

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/sqlite"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

model Candidate {
  id              String   @id @default(uuid())
  nisn            String   @unique
  name            String
  className       String
  whatsappNumber  String
  email           String
  gender          String
  asalSekolah     String   @default("-")
  reason          String
  status          String   @default("PENDING")
  photoPath       String?
  
  // Authentication fields for Member Login
  password        String?  // Hashed password
  plainPassword   String?  // Plaintext password for Admin export/view
  
  // Notification status
  emailNotified   Boolean  @default(false)
  waNotified      Boolean  @default(false)
  lastStatus      String   @default("PENDING")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("KABINET_UMUM")
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String    @id @default(uuid())
  title     String
  slug      String    @unique
  content   String
  authorId  String
  author    Admin     @relation(fields: [authorId], references: [id])
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  username  String
  content   String
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model Member {
  id              String   @id @default(uuid())
  nisn            String   @unique
  name            String
  className       String
  whatsappNumber  String
  email           String
  gender          String
  asalSekolah     String   @default("-")
  password        String
  plainPassword   String?
  status          String   @default("ACTIVE")
  joinYear        Int      @default(2026)
  role            String   @default("member")
  photoPath       String?
  orgMember       OrgMember?  // back-relation
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrgMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  jabatan     String
  yearStart   Int
  yearEnd     Int?
  isCurrent   Boolean  @default(false)
  photoPath   String?  // used only for orphan entries (no linked Member account)
  quote       String?
  memberId    String?  @unique // FK to Member (nullable)
  member      Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AlumniTestimonial {
  id          String   @id @default(uuid())
  name        String
  angkatan    String
  photoPath   String?
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

