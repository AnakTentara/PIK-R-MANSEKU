datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/mysql"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

model Candidate {
  id              String   @id @default(uuid())
  nisn            String   @unique
  name            String
  className       String
  whatsappNumber  String
  email           String
  gender          String
  asalSekolah     String   @default("-")
  reason          String   @db.Text
  status          Status   @default(PENDING)
  photoPath       String?
  
  // Authentication fields for Member Login
  password        String?  // Hashed password
  plainPassword   String?  // Plaintext password for Admin export/view
  
  // Notification status
  emailNotified   Boolean  @default(false)
  waNotified      Boolean  @default(false)
  lastStatus      Status   @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Status {
  PENDING
  LULUS
  TIDAK_LULUS
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("KABINET_UMUM")
  posts     Post[]
  blogPosts BlogPost[] // Relation to BlogPost
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String    @id @default(uuid())
  title     String
  slug      String    @unique
  content   String    @db.LongText
  authorId  String
  author    Admin     @relation(fields: [authorId], references: [id])
  views     Int       @default(0) // views count
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model BlogPost {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  content      String        @db.LongText
  category     String        @default("Umum")
  tags         String        @default("") // Comma-separated tags
  status       String        @default("DRAFT") // DRAFT | PUBLISHED
  featuredImg  String?
  views        Int           @default(0)
  authorId     String?       // FK to Admin (optional)
  memberId     String?       // FK to Member (optional)
  author       Admin?        @relation(fields: [authorId], references: [id])
  memberAuthor Member?       @relation(fields: [memberId], references: [id])
  comments     BlogComment[]
  likes        BlogLike[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BlogComment {
  id        String        @id @default(uuid())
  postId    String
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  content   String        @db.Text
  memberId  String?       // FK to Member (optional, if logged in)
  member    Member?       @relation(fields: [memberId], references: [id])
  username  String        // fallback for guest
  parentId  String?
  parent    BlogComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentThread")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model BlogLike {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  memberId  String?  // Nullable for guest
  member    Member?  @relation(fields: [memberId], references: [id])
  guestId   String?  // string for guest
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String @db.Text
}

model Member {
  id              String   @id @default(uuid())
  nisn            String?  @unique
  name            String
  className       String
  whatsappNumber  String
  email           String
  gender          String
  asalSekolah     String   @default("-")
  password        String
  plainPassword   String?
  status          MemberStatus @default(ACTIVE)
  joinYear        Int      @default(2026)
  role            String   @default("member")
  photoPath       String?
  orgMember       OrgMember?   // back-relation: a Member can be linked to one OrgMember entry
  blogPosts       BlogPost[]   // written posts
  blogComments    BlogComment[] // posted comments
  blogLikes       BlogLike[]   // likes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum MemberStatus {
  ACTIVE
  ALUMNI
}

model OrgMember {
  id          String   @id @default(uuid())
  name        String
  role        String   // PEMBINA, KETUA, WAKIL, KABINET, ANGGOTA
  jabatan     String   // e.g. "Pembina", "Ketua Umum", "Kabid Kesehatan"
  yearStart   Int
  yearEnd     Int?
  isCurrent   Boolean  @default(false)
  photoPath   String?  // used only for orphan entries (no linked Member account)
  quote       String?  @db.Text
  memberId    String?  @unique // FK to Member (nullable — allows historical orphan entries)
  member      Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordResetOtp {
  id          String   @id @default(uuid())
  identifier  String   // NISN or WA number
  otpCode     String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model AlumniTestimonial {
  id          String   @id @default(uuid())
  name        String
  angkatan    String   // e.g. "2023", "2024"
  photoPath   String?
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

